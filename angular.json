{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm",
    "schematicCollections": [
      "angular-eslint"
    ]
  },
  "newProjectRoot": "projects",
  "projects": {
    "tsp-client-app": {
      "projectType": "application",
      "schematics": {},
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "i18n": {
        "sourceLocale": {
          "code": "en-US",
          "subPath": "en"
        },
        "locales": {
          "ru-BY": {
            "translation": "src/locale/messages.ru.xlf",
            "subPath": "ru"
          },
          "pl-PL": {
            "translation": "src/locale/pl-PL.xlf",
            "subPath": "pl"
          },
          "de-DE": {
            "translation": "src/locale/de-DE.xlf",
            "subPath": "de"
          },
          "ka-GE": {
            "translation": "src/locale/ka-GE.xlf",
            "subPath": "ka"
          },
          "tr-TR": {
            "translation": "src/locale/tr-TR.xlf",
            "subPath": "tr"
          },
          "el-GR": {
            "translation": "src/locale/el-GR.xlf",
            "subPath": "el"
          },
          "ar-AE": {
            "translation": "src/locale/ar-AE.xlf",
            "subPath": "ar"
          }
        }
      },
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "src/main.ts",
            "tsConfig": "tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              }
            ],
            "styles": [
              "src/material-theme.scss",
              "src/styles.scss"
            ],
            "polyfills": [
              "@angular/localize/init"
            ],
            "localize": true
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "1MB",
                  "maximumError": "4MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true,
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.development.ts"
                }
              ]
            },
            "development-ru": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true,
              "localize": [
                "ru-BY"
              ],
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.development.ts"
                }
              ]
            },
            "development-pl": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true,
              "localize": [
                "pl-PL"
              ],
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.development.ts"
                }
              ]
            },
            "development-de": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true,
              "localize": [
                "de-DE"
              ],
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.development.ts"
                }
              ]
            },
            "development-ka": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true,
              "localize": [
                "ka-GE"
              ],
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.development.ts"
                }
              ]
            },
            "development-tr": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true,
              "localize": [
                "tr-TR"
              ],
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.development.ts"
                }
              ]
            },
            "development-el": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true,
              "localize": [
                "el-GR"
              ],
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.development.ts"
                }
              ]
            },
            "development-ar": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true,
              "localize": [
                "ar-AE"
              ],
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.development.ts"
                }
              ]
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "tsp-client-app:build:production"
            },
            "development": {
              "buildTarget": "tsp-client-app:build:development"
            },
            "ru": {
              "buildTarget": "tsp-client-app:build:development-ru"
            },
            "pl": {
              "buildTarget": "tsp-client-app:build:development-pl"
            },
            "de": {
              "buildTarget": "tsp-client-app:build:development-de"
            },
            "ka": {
              "buildTarget": "tsp-client-app:build:development-ka"
            },
            "tr": {
              "buildTarget": "tsp-client-app:build:development-tr"
            },
            "el": {
              "buildTarget": "tsp-client-app:build:development-el"
            },
            "ar": {
              "buildTarget": "tsp-client-app:build:development-ar"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test"
        },
        "extract-i18n": {
          "builder": "@angular/build:extract-i18n",
          "options": {
            "buildTarget": "tsp-client-app:build",
            "format": "xlf",
            "outputPath": "src/locale",
            "outFile": "messages.en.xlf"
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "src/**/*.ts",
              "src/**/*.html"
            ]
          }
        }
      }
    }
  }
}